FOXSCAN_API_BASE_URL=https://api.foxscan.fr
DATABASE_URL=postgresql://user:password@localhost:5432/foxscan
JWT_SECRET=change-me
JWT_REFRESH_SECRET=change-me-too
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=2592000
FOXSCAN_DB_PATH=apps/api/data/foxscan.db
DASHBOARD_REQUIRE_ACTIVE_SUBSCRIPTION=true
DEFAULT_SUBSCRIPTION_STATUS=inactive
# Sign in with Apple
# Team ID : depuis developer.apple.com (en haut à droite)
APPLE_TEAM_ID=change-me
# Bundle ID iOS (App ID principal)
APPLE_BUNDLE_ID=PE.FOXSCAN
# Services ID Web (créé dans Identifiers > Services IDs)
APPLE_WEB_CLIENT_ID=fr.foxscan.web
# Key ID de la clé .p8 Sign in with Apple (10 caractères)
APPLE_KEY_ID=change-me
# Chemin absolu vers la clé .p8 sur le serveur (jamais dans Git)
APPLE_PRIVATE_KEY_PATH=/home/USER/domains/foxscan.fr/nodejs/AuthKey_KEYID.p8

# Sign in with Google
# OAuth 2.0 Client ID (type "Web application") créé dans console.cloud.google.com
# JavaScript origins autorisés : https://foxscan.fr
# Redirect URIs autorisés : https://foxscan.fr/login.html
GOOGLE_CLIENT_ID=000000000000-xxxxxxxxxxxxxxxxxxxxxxxxxxxxx.apps.googleusercontent.com
